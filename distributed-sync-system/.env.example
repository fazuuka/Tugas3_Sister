APP_ENV=dev
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
NODE_HOST=0.0.0.0
NODE_PORT=8000
NODE_ID=node-1
NODE_ROLE=lock
PEERS=node-2:8001,node-3:8002
TLS_ENABLED=false
TLS_CERT_FILE=./certs/node.pem
TLS_KEY_FILE=./certs/node.key
TLS_CA_FILE=./certs/ca.pem
RBAC_ENABLED=true
RBAC_TOKEN=dev-token-1
RBAC_TOKENS=dev-token-1:node,dev-token-admin:admin
RBAC_PERMISSIONS=node:raft.*|lock.*|queue.*|cache.*,admin:*
PARTITION_BLOCKLIST=
PARTITION_DROP_RATE=0.0
QUEUE_VISIBILITY_TIMEOUT=30
QUEUE_RECOVERY_INTERVAL=10
QUEUE_VNODES=50
QUEUE_REPLICATION=2
QUEUE_MEMBERSHIP_REFRESH=5
CACHE_POLICY=LRU
CACHE_CAPACITY=1000
CACHE_MEMBERSHIP_REFRESH=5
